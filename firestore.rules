rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Admin check via Firestore role field only
      // Set role: 'admin' manually in Firebase Console for admin users
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Reviews
    match /reviews/{reviewId} {
      function isValidReview(data) {
        return data.productId is string &&
               data.userId == request.auth.uid &&
               data.userName is string &&
               data.rating is int && data.rating >= 1 && data.rating <= 5 &&
               data.comment is string && data.comment.size() <= 1000 &&
               data.createdAt is timestamp;
      }

      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data);
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Wishlist
    match /wishlist/{wishlistId} {
      function isValidWishlist(data) {
        return data.userId == request.auth.uid &&
               data.productId is string &&
               data.createdAt is timestamp;
      }
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidWishlist(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Addresses
    match /addresses/{addressId} {
      function isValidAddress(data) {
        return data.userId == request.auth.uid &&
               data.name is string && data.name.size() > 0 &&
               data.phone is string && data.phone.size() >= 10 &&
               data.street is string &&
               data.city is string &&
               data.state is string &&
               data.pincode is string &&
               data.createdAt is timestamp;
      }
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidAddress(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidAddress(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // UGC Gallery
    match /ugc/{ugcId} {
      function isValidUGC(data) {
        return data.imageUrl is string &&
               data.status in ['pending', 'approved', 'rejected'] &&
               data.createdAt is timestamp;
      }
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow create: if isAuthenticated() && isValidUGC(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Connection check
    match /_connection_test_/{docId} {
      allow read: if true;
    }
  }
}
