# ─────────────────────────────────────────────────────────────────
# Devaragudi Ethnic Threads — All Environment Variables
# Add ALL of these in Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── Razorpay ──────────────────────────────────────────────────────
# dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_... while testing, rzp_live_... after KYC
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Gemini AI ─────────────────────────────────────────────────────
# aistudio.google.com → Get API Key
# Add the SAME key to both — VITE_ prefix exposes it to the browser
GEMINI_API_KEY=AIzaSy...
VITE_GEMINI_API_KEY=AIzaSy...

# ── Shiprocket ────────────────────────────────────────────────────
# Sign up free at app.shiprocket.in (no minimum shipments)
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your_shiprocket_password

# ── Email (Gmail App Password) ────────────────────────────────────
# Gmail → Settings → Security → 2FA → App Passwords → Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourstore@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ── Firebase Admin SDK ────────────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate Key
# Download the JSON — extract these 3 values
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# Paste the private key WITH the quotes, exactly as in the downloaded JSON
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# ── App config (VITE_ prefix = visible in browser) ───────────────
APP_URL=https://shubhvastram.in
VITE_ADMIN_EMAIL=your-admin@gmail.com
VITE_CONTACT_EMAIL=support@shubhvastram.in
VITE_INSTAGRAM_URL=https://instagram.com/devaragudi
VITE_FACEBOOK_URL=https://facebook.com/devaragudi
